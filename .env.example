# Backend env for FARKA
# DATABASE_URL is required and must be a Postgres/Supabase URL.

# Supabase direct connection:
# DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Supabase pooler connection:
# DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Important:
# - copy the exact URI from Supabase
# - prefer port 5432 for the current Supabase-generated pooler URI
# - remove any older localhost/sqlite fallback values from the environment

# Optional for live OpenAI-backed chat/checklist generation.
# If left empty, the backend will use deterministic fallback logic.
OPENAI_API_KEY=

# Optional future config values
OPENAI_MODEL=gpt-5.4-mini
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# You can use one shared voice or separate Nepali / English voices.
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_NE=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_VOICE_EN=
OPENAI_TTS_VOICE_NE=
APP_ENV=production
# Supports comma-separated origins for local + deployed frontend together.
CORS_ORIGINS=http://localhost:3000,https://farka-fe.vercel.app

# WhatsApp / Twilio integration
# Sign up at https://www.twilio.com, then enable the WhatsApp Sandbox under Messaging > Try it out > Send a WhatsApp message
# Set the sandbox webhook URL to: https://<your-backend-url>/api/v1/whatsapp/webhook
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The URL of your deployed frontend — sent to users as the magic link
APP_URL=https://farka-fe.vercel.app
