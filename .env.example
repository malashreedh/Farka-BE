# Local backend env for FARKA
# Copy this file to `.env` and fill in real values if needed.

# Recommended for easy local testing
DATABASE_URL=sqlite:///./farka_dev.db

# If you want local Postgres instead, replace DATABASE_URL with:
# DATABASE_URL=postgresql://farka_user:farka2026@localhost/farka_db

# If you want Supabase Postgres instead, replace DATABASE_URL with something like:
# DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Optional for live OpenAI-backed chat/checklist generation.
# If left empty, the backend will use deterministic fallback logic.
OPENAI_API_KEY=

# Optional future config values
OPENAI_MODEL=gpt-4o-mini
APP_ENV=local
# Supports comma-separated origins for local + deployed frontend together.
CORS_ORIGINS=http://localhost:3000,https://farka-fe.vercel.app
